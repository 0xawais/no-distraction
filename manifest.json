{
  "manifest_version": 3,
  "name": "No Distraction!",
  "version": "1.0.0",
  "description": "Requires solving a 7th grade math problem to unlock distracting websites.",
  "permissions": ["storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {"service_worker": "background.js"},
  "options_ui": {"page": "options.html", "open_in_tab": true},
  "action": {"default_title": "No Distraction! Options", "default_popup": "options.html"}
}